{
  "expo": {
    "name": "Palnadu MACS Soldiers",
    "slug": "palnadu-macs-soldiers",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "palnadumacs",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1437"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.palnadumacs.soldiers"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1437"
      },
      "package": "com.palnadumacs.soldiers"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": ["expo-blur"]
  }
}
